---
const supported = ["en", "de", "es"];

const pathname = Astro.url?.pathname ?? "/";
const segments = pathname.split("/").filter(Boolean);

const hasLangPrefix = supported.includes(segments[0] ?? "");
const currentLang = hasLangPrefix ? segments[0] : "en";

const restPath = hasLangPrefix
    ? segments.slice(1).join("/")
    : segments.join("/");

// detect dynamic (md-driven) routes
const isMdRoute = segments.includes("projects") || segments.includes("posts")
    ? segments.length > (hasLangPrefix ? 2 : 1)
    : false;

// ONLY load md pages for checking
const pages = Object.keys(import.meta.glob("/src/pages/**/*.md"));

function toRoute(filePath) {
    return filePath
        .replace("/src/pages", "")
        .replace(/\.md$/, "")
        .replace(/\/index$/, "");
}

const routeSet = new Set(pages.map(toRoute));

function buildLangPath(lang) {
    return `/${lang}${restPath ? `/${restPath}` : ""}`;
}

function translationExists(lang) {
    if (!isMdRoute) return true; // ⬅️ KEY FIX

    const target = buildLangPath(lang);
    return routeSet.has(target);
}

function makeHref(lang) {
    return buildLangPath(lang);
}
---

<nav class="site-language" aria-label="Language selector">
    <a
        class={`lang-button ${currentLang === "en" ? "is-active" : ""} ${
            !translationExists("en") ? "is-disabled" : ""
        }`}
        href={translationExists("en") ? makeHref("en") : undefined}
        aria-current={currentLang === "en" ? "page" : undefined}
    >
        EN
    </a>

    <span class="lang-sep" aria-hidden="true">|</span>

    <a
        class={`lang-button ${currentLang === "de" ? "is-active" : ""} ${
            !translationExists("de") ? "is-disabled" : ""
        }`}
        href={translationExists("de") ? makeHref("de") : undefined}
        aria-current={currentLang === "de" ? "page" : undefined}
    >
        DE
    </a>

    <span class="lang-sep" aria-hidden="true">|</span>

    <a
        class={`lang-button ${currentLang === "es" ? "is-active" : ""} ${
            !translationExists("es") ? "is-disabled" : ""
        }`}
        href={translationExists("es") ? makeHref("es") : undefined}
        aria-current={currentLang === "es" ? "page" : undefined}
    >
        ES
    </a>
</nav>

<style>
    .site-language {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.2rem 0 0.1rem;
    }

    .lang-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.6rem;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        color: var(--color-primary);
        text-decoration: none;
        font-weight: 700;
        letter-spacing: 0.12em;
    }

    .lang-button.is-active {
        color: var(--color-secondary);
    }

    .lang-button:hover {
        color: white;
    }

    .lang-button.is-disabled {
        color: rgba(255, 255, 255, 0.35);
        pointer-events: none;
        cursor: default;
    }

    .lang-button.is-disabled:hover {
        color: rgba(255, 255, 255, 0.35);
    }

    .lang-sep {
        color: rgba(255, 255, 255, 0.5);
        font-weight: 700;
    }

    @media (max-width: 640px) {
        .site-language {
            gap: 0.35rem;
            padding: 0.2rem 0 0.1rem;
        }

        .lang-button {
            min-width: 2.2rem;
            padding: 0.25rem 0.55rem;
            font-size: 0.85rem;
        }
    }
</style>
