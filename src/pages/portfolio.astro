---
import BaseLayout from '../layouts/BaseLayout.astro';
import LanguageIcons from '../components/LanguageIcons.astro';
import '../styles/global.css';
const allProjects = Object.values(import.meta.glob('./docs/*.md', { eager: true }));
---

<BaseLayout pageTitle="Projects" containerWidth="max-w-4xl" fullHeight={true} showBackButton={true}>
    <style>
        .project-grid {
            display: grid;
            gap: 1.5rem;
        }

        .project-card {
            background-color: rgba(107, 114, 128, 0.3);
            border: 1px solid rgba(107, 114, 128, 0.5);
            border-radius: 0.5rem;
            padding: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            color: white;
        }

        .project-card:hover {
            background-color: rgba(107, 114, 128, 0.5);
            border-color: rgba(107, 114, 128, 0.8);
            transform: translateY(-2px);
        }

        .project-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }

        .project-title {
            font-size: 1.25rem;
            font-weight: bold;
            color: rgb(49, 220, 154);
            margin: 0;
        }

        .project-description {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.95rem;
            line-height: 1.5;
        }
    </style>
    <p>A few of the projects I'm most proud of. For all my public projects check my <a href="https://github.com/KixiKcodes">GitHub</a>.</p>
    <div class="project-grid">
        {allProjects.map((project: any) => (
            <a href={project.url} class="project-card">
                <div class="project-header">
                    <div class="project-title">{project.frontmatter.title}</div>
                    <LanguageIcons tags={project.frontmatter.tags ?? []} />
                </div>
                <div class="project-description">{project.frontmatter.description}</div>
            </a>
        ))}
    </div>
</BaseLayout>
