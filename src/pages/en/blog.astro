---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
const localizedPosts = Object.values(import.meta.glob("./posts/*.md", { eager: true }));
const allPosts = (localizedPosts.length
    ? localizedPosts
    : Object.values(import.meta.glob("../posts/*.md", { eager: true })))
    .sort((a: any, b: any) => {
        const dateA = new Date(a.frontmatter?.pubDate ?? 0).getTime();
        const dateB = new Date(b.frontmatter?.pubDate ?? 0).getTime();
        return dateB - dateA;
    });
---

<BaseLayout pageTitle="Blog" containerWidth="max-w-4xl" fullHeight={true} showBackButton={true} lang="en">
    <style>
        .post-grid {
            display: grid;
            gap: 1.5rem;
        }

        .post-card {
            background-color: rgba(107, 114, 128, 0.3);
            border: 1px solid rgba(107, 114, 128, 0.5);
            border-radius: 0.5rem;
            padding: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            color: white;
        }

        .post-card:hover {
            background-color: rgba(107, 114, 128, 0.5);
            border-color: rgba(107, 114, 128, 0.8);
            transform: translateY(-2px);
        }

        .post-title {
            font-size: 1.25rem;
            font-weight: bold;
            color: rgb(49, 220, 154);
            margin-bottom: 0.5rem;
        }

        .post-description {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .post-date {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.85rem;
            text-align: right;
        }
    </style>
    <p>Some stuff I write from time to time.</p>
    <div class="post-grid">
        {allPosts.map((post: any) => (
            <a href={post.url} class="post-card">
                <div class="flex justify-between">
                    <div class="post-title">{post.frontmatter.title}</div>
                    <div class="post-date">{post.frontmatter.pubDate?.toString().slice(0, 10)}</div>
                </div>
                <div class="post-description">{post.frontmatter.description}</div>
            </a>
        ))}
    </div>
</BaseLayout>
