---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title} containerWidth="max-w-4xl" fullHeight={true} showBackButton={true}>
    <div class="project-info">
        <h5>{frontmatter.pubDate.toString().slice(0, 10)}</h5>
        <a href={frontmatter.source}>Source Code</a>
    </div>
    <slot />
</BaseLayout>

<style>
    .project-info {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
</style>
